GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TEMPERATURE=0.7
GROQ_MAX_TOKENS=800
# Ngân sách token cho lịch sử hội thoại gửi kèm mỗi lượt (cắt bớt message cũ khi vượt).
GROQ_CONTEXT_TOKENS=6000
# Số lần thử lại khi gặp lỗi tạm thời (rate limit, mất mạng, lỗi server Groq).
GROQ_MAX_RETRIES=3
# Số bước tối đa của agent trong một lượt trả lời (mỗi bước có thể gọi công cụ).
GROQ_AGENT_MAX_STEPS=5
# Model embedding cho tìm kiếm ngữ nghĩa (đa ngôn ngữ, hỗ trợ tiếng Việt).
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
